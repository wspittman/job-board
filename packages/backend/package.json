{
  "name": "backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "lint": "eslint",
    "format": "prettier . --write",
    "test": "node --import tsx --import ./test/setup.ts --test --test-reporter=dot test/**/*.test.ts",
    "test-details": "node --import tsx --import ./test/setup.ts --test test/**/*.test.ts",
    "dev": "tsx watch --import ./register-otel.mjs --env-file=./.env ./src/app.ts",
    "build": "tsc",
    "start": "node --import ./register-otel.mjs dist/app.js"
  },
  "dependencies": {
    "applicationinsights": "^3.14.0",
    "cors": "^2.8.5",
    "dry-utils-async": "^0.3.2",
    "dry-utils-cosmosdb": "^0.6.0",
    "dry-utils-openai": "^0.4.2",
    "dry-utils-text": "^0.2.1",
    "express": "^5.1.0",
    "helmet": "^8.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/node": "^24.10.0",
    "eslint": "^10.0.0",
    "prettier": "^3.7.4",
    "tsx": "^4.7.1",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.56.0"
  }
}
