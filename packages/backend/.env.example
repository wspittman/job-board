# =============================================================================
# Required — no defaults; the server will not start without these.
# =============================================================================

# Secret token used to authenticate admin API requests (min 16 chars).
ADMIN_TOKEN=unset

# OpenAI API key used for all LLM operations.
OPENAI_API_KEY=unset

# =============================================================================
# Server — defaults shown; override only when needed.
# =============================================================================

# HTTP port the Express server listens on.
# PORT=3000

# Runtime environment; controls logging and behavior.
# NODE_ENV=dev

# =============================================================================
# Database — defaults target the local CosmosDB Emulator.
# =============================================================================

# CosmosDB account endpoint.
# DATABASE_URL=https://localhost:8081

# CosmosDB account key. The default is the well-known local emulator key.
# DATABASE_KEY=C2y6yDjf5/R+ob0N8A7Cgv30VRDJIWEHLM+4QDU5DE2nQ9nDuVTqobD4b8mGGyPMbIZnqyMsEcaGQy67XIw/Jw==

# Path to the self-signed TLS certificate for the local emulator.
# DATABASE_LOCAL_CERT_PATH=./cosmosdbcert.cer

# Optional: inline JSON mock data, keyed by container name. Enables in-memory
# DB for environments without a CosmosDB Emulator (e.g. CI, agent containers).
# Example: {"company":[{"id":"acme","ats":"greenhouse","name":"Acme"}],"job":[]}
# DATABASE_MOCK_DATA_JSON=unset

# Optional: path to a JSON file with the same structure as DATABASE_MOCK_DATA_JSON.
# File-based options load first; inline JSON overrides duplicate container keys.
# Example: ./mock-db-options.json
# DATABASE_MOCK_DATA_PATH=unset

# =============================================================================
# ATS — defaults point to public API endpoints.
# =============================================================================

# Greenhouse Boards API base URL.
# GREENHOUSE_URL=https://boards-api.greenhouse.io/v1/boards

# Lever Postings API base URL.
# LEVER_URL=https://api.lever.co/v0/postings

# =============================================================================
# LLM — defaults shown; override to tune model selection and reasoning budget.
# =============================================================================

# Default model for all LLM operations.
# LLM_MODEL=gpt-5-nano

# Default reasoning effort applied to all operations.
# Valid values: none | minimal | low | medium | high | xhigh
# LLM_REASONING_EFFORT=minimal

# Per-operation model overrides as a JSON object (keys are operation names).
# Operation names: extractLocation, fillCompanyInfo, fillJobInfo,
#                  isGeneralApplication, interpretFilters
# Example: {"fillJobInfo":"gpt-5-mini"}
# LLM_MODEL_OVERRIDES={}

# Per-operation reasoning effort overrides as a JSON object.
# Example: {"fillJobInfo":"low"}
# LLM_REASONING_EFFORT_OVERRIDES={}

# JSON array of operation names that should prefer Flex processing.
# Example: ["fillJobInfo","fillCompanyInfo"]
# LLM_PREFER_FLEX=[]

# =============================================================================
# Telemetry — defaults to a no-op dummy key; set a real connection string for
# production Application Insights telemetry.
# =============================================================================

# Azure Application Insights connection string.
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=dummy_key

# Set to true to log verbose details to console
# ENABLE_VERBOSE_BLOB_LOGGING=false
