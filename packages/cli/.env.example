# =============================================================================
# Required — no defaults; the CLI will not run without these.
# =============================================================================

# Secret token for admin API requests. Must match the value in the local backend .env.
ADMIN_TOKEN=unset

# OpenAI API key. Used directly by the OpenAI SDK.
# Must be present for cli to run, must be valid for LLM commands (evals, e2e) to work.
OPENAI_API_KEY=unset

# =============================================================================
# API URLs — defaults shown; override to target a different environment.
# =============================================================================

# Base URL for the local backend API.
# API_URL=http://localhost:3000/api/

# Base URL for the production backend API.
# PROD_API_URL=https://api.betterjobboard.net/api/

# =============================================================================
# Production credentials — optional; required only for production API commands.
# =============================================================================

# Admin token for the production API. Keep secret; do not commit.
# PROD_ADMIN_TOKEN=unset

# =============================================================================
# E2E test fixtures — optional; required to run e2e tests.
# Format: pipe-separated `ats:id1,id2` entries. Prefer companies with 3–5 jobs each.
# Example: greenhouse:company-a,company-b|lever:company-c
# =============================================================================

# E2E_COMPANIES=

# =============================================================================
# Backend - See packages/backend/.env.example for more options
# These are used by CLI commands that directly reference backend code (ats, evals)
# The backend .env will not be used when running from CLI
# =============================================================================