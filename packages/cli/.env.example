# Backend and LLM settings reused by commands copied from packages/lab
ADMIN_TOKEN=unset
OPENAI_API_KEY=unset
GEMINI_API_KEY=unset
LLM_MODEL=gpt-5-nano
LLM_REASONING_EFFORT=minimal

# Ops API settings reused by commands copied from packages/ops
# Bearer token with admin privileges
PROD_API_TOKEN=unset
LOCAL_API_TOKEN=unset

# Comma-separated list of company IDs for e2e tests
# Use three companies with a preference for 3-5 jobs each
GREENHOUSE_IDS=unset
LEVER_IDS=unset
