# Local
# ADMIN_TOKEN is required and should match the value set in the backend .env file.
ADMIN_TOKEN=unset

# LLM Settings
# OPENAI_API_KEY is required for any CLI commands make LLM calls (eg. evals)
OPENAI_API_KEY=unset

# Comma-separated list of company IDs for e2e tests
# Use three companies with a preference for 3-5 jobs each
GREENHOUSE_IDS=unset
LEVER_IDS=unset